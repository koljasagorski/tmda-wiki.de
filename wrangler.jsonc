{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tmda-wiki",
  "main": "src/index.js",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "REPO_URL": "https://github.com/koljasagorski/tmda-wiki.de"
  }
}
